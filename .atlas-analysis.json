  },
  "keyFeatures": [
    "JWT-based authentication with automatic token refresh",
    "Fluvial vessel registration (empadronamiento) with multi-step form",
    "Appointment management with agenda, scheduling, and history",
    "Dashboard with real-time statistics and KPI cards",
    "Portal web content management (tramites and noticias)",
    "Interactive guided tours using driver.js",
    "Voice guide accessibility feature for forms",
    "Vessel owner management (propietarios de naves)",
    "Document reception and review workflow",
    "Collapsible sidebar navigation with role-based sections"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
    "POST /api/auth/refresh",
    "POST /api/auth/logout",
    "GET /api/dashboard",
    "GET /api/dashboard/stats",
    "GET /api/personas/lookup?doc={dniRuc}",
    "GET /api/catalogo/tipos-nave",
    "GET /api/catalogo/materiales",
    "GET /api/catalogo/modalidades",
    "GET /api/catalogo/servicios-nave",
    "GET /api/catalogo/ubicaciones",
    "GET /api/propietarios"
  ]
}
