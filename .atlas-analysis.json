{
  "projectType": "saas",
  "projectName": "DRTC Fluvial Admin",
  "projectDescription": "A Next.js administrative panel for the Regional Directorate of Transport and Communications (DRTC Amazonas) that manages river vessel registrations, appointments, permits, and web portal content.",
  "theme": "luma",
  "primaryColor": "#001f3f",
  "lightColor": "#e9f0f6",
  "darkColor": "#001224",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/dashboard",
              "features/appointments",
              "features/vessel-registration",
              "features/permits-renewal"
            ]
          },
          {
            "group": "Portal Web Management",
            "pages": [
