              "portal/noticias"
            ]
          },
          {
            "group": "Configuration & Deployment",
            "pages": [
              "configuration/environment",
              "configuration/backend-integration",
              "configuration/deployment"
            ]
          }
        ]
      },
      {
        "tab": "Developer Reference",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
